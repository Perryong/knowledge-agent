# Copy to ~/.hermes/.env  — NEVER commit the real file (it holds secrets).
# capture-note.sh and llm_link.py read these from the environment.

# --- Telegram (from @BotFather; lock allowed users to your own numeric id) ---
TELEGRAM_BOT_TOKEN=123456789:replace-with-botfather-token
TELEGRAM_ALLOWED_USERS=000000000

# --- Vault location (point both at this repo) ---
OBSIDIAN_VAULT_PATH=/absolute/path/to/COG-second-brain
VAULT_ROOT=/absolute/path/to/COG-second-brain

# --- Optional LLM wiki-linker -------------------------------------------------
# Leave HERMES_LINK_API_KEY blank to use the free, deterministic exact-match linker.
# Set it (OpenAI-compatible endpoint) to also catch paraphrased concepts.
HERMES_LINK_API_BASE=https://openrouter.ai/api/v1
HERMES_LINK_API_KEY=
HERMES_LINK_MODEL=nousresearch/hermes-4-70b
HERMES_LINK_MAX=12

# --- Runtime / debug ----------------------------------------------------------
# HERMES_PYTHON=python             # set if `python3` isn't your interpreter (e.g. Windows)
# HERMES_CAPTURE_DEBUG=1           # dump raw hook payload to inspect its JSON schema
# HERMES_CAPTURE_DEBUG_LOG=/tmp/hermes-payload.log
# Captures use atomic writes + unique filenames, so no lockfile is needed.

# NOTE: git push auth (deploy key or fine-grained PAT) lives in the shell/ssh
# environment of whoever runs batch_enrich.sh — NOT in this file, NOT in the repo.
